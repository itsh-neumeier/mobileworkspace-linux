DOMAIN_OR_HOST=:80
TIMEZONE=Europe/Berlin
ADMIN_UI_IMAGE_TAG=latest
MWC_EDGE_NETWORK=mobileworkspace_edge
MWC_PUBLIC_NETWORK=mobileworkspace_public_net
MWC_INTERNAL_NETWORK=mobileworkspace_internal_net

ADMIN_USER_NAME=admin
ADMIN_INITIAL_PASSWORD=admin

# Provisioning backend: docker | proxmox_vm
MWC_PROVISIONER_MODE=docker

# Proxmox VM mode (required when MWC_PROVISIONER_MODE=proxmox_vm)
MWC_PROXMOX_API_URL=
MWC_PROXMOX_NODE=
MWC_PROXMOX_TOKEN_ID=
MWC_PROXMOX_TOKEN_SECRET=
MWC_PROXMOX_TEMPLATE_VMID=
MWC_PROXMOX_VM_CORES=2
MWC_PROXMOX_VM_MEMORY_MB=4096
MWC_PROXMOX_VM_DISK=
MWC_PROXMOX_NET_BRIDGE=vmbr0
MWC_PROXMOX_VM_START_ON_CREATE=true
MWC_PROXMOX_VERIFY_TLS=true
