      --accent: #6ee7b7;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 24px;
      background:
        radial-gradient(circle at top right, rgba(110, 231, 183, 0.18), transparent 28%),
        linear-gradient(160deg, #07111f 0%, #101d34 100%);
      color: var(--text);
