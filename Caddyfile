{$DOMAIN_OR_HOST} {
	handle_path /admin/* {
		basicauth {
			{$ADMIN_USER_NAME} {$ADMIN_USER_PASSWORD_HASH}
		}
		reverse_proxy admin-ui:8080
	}

	import /etc/caddy/Caddy.users

	handle {
		respond <<HTML
<!doctype html>
<html lang="en">
